# ==========================================
# Turbo Performance - ZRAM Configuration
# ==========================================
# ملحوظة: ZRAM_SIZE بقى بيتحسب ديناميكياً في service.sh
# حسب رام الجهاز الفعلي (نسبة مئوية)، مش رقم ثابت.
# لو عايز تتحكم في النسبة، غيّر ZRAM_PERCENT بس.

ZRAM_ALGO=lz4
ZRAM_PERCENT=50
